{
  "name": "trecker",
  "version": "0.1.0",
  "private": true,
  "description": "Личный трекер активностей (подтягивания, чтение, учёба) на Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute trecker --file=./schema.sql",
    "db:init:local": "wrangler d1 execute trecker --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
